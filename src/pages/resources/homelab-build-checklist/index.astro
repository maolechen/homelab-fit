---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const checks = [
  {
    title: "Mini PC NAS Pre-buy Scorecard",
    items: [
      "Write the exact model, CPU, RAM ceiling, and NIC model before comparing prices.",
      "Score storage ownership: Proxmox-managed disks, NAS VM passthrough, or external NAS.",
      "Confirm where the first real backup will live outside the mini PC.",
      "Mark any unknown NIC, drive, cooling, or restore detail as a buying blocker."
    ]
  },
  {
    title: "Host Fit",
    items: [
      "Confirm CPU virtualization support and BIOS options.",
      "Record RAM capacity, replaceability, and realistic workload headroom.",
      "Identify the exact NIC model, not only the port speed.",
      "Check cooling, noise, power supply, and whether the chassis can sustain your workload."
    ]
  },
  {
    title: "Storage Path",
    items: [
      "List every boot, VM, container, NAS, and backup disk.",
      "Decide whether Proxmox or a NAS VM owns each disk.",
      "For ZFS, plan drive count, mirror/raidz shape, scrub checks, and capacity headroom.",
      "Keep the backup destination off the same host."
    ]
  },
  {
    title: "Networking",
    items: [
      "Record expected link speed, switch port, cable type, and bridge name.",
      "Keep local console access before changing network config.",
      "Test sustained transfers after install.",
      "Document VLANs and gateway settings if the host is also a firewall lab."
    ]
  },
  {
    title: "Passthrough And Recovery",
    items: [
      "Confirm IOMMU support and device isolation before buying around passthrough.",
      "Keep Proxmox boot storage separate from passed-through controllers.",
      "Write a rollback plan for HBA, GPU, and USB passthrough changes.",
      "Run a restore test before storing important data."
    ]
  }
];
---
<BaseLayout title="Proxmox Homelab Pre-buy Scorecard | Homelab Fit" description="A free Proxmox homelab pre-buy scorecard for mini PCs, NICs, ZFS storage, passthrough, backups, and recovery.">
  <section class="page-head">
    <p class="eyebrow">Free checklist</p>
    <h1>Proxmox homelab pre-buy scorecard</h1>
    <p>A practical scorecard for mini PC NAS builds, 2.5G networking, ZFS mirrors, HBA passthrough, and recovery-ready homelab operations.</p>
    <div class="hero-actions">
      <a class="button-link" href="/resources/mini-pc-nas-scorecard/">Open interactive scorecard</a>
      <a class="button-link secondary" href="/downloads/proxmox-homelab-build-checklist.md">Download Markdown checklist</a>
    </div>
  </section>

  <section class="checklist-grid">
    {checks.map((group) => (
      <article class="content-section">
        <h2>{group.title}</h2>
        <ul>{group.items.map((item) => <li>{item}</li>)}</ul>
      </article>
    ))}
  </section>

  <section class="content-section">
    <h2>Related Pages</h2>
    <div class="template-links">
      <a href="/resources/mini-pc-nas-scorecard/">
        <strong>Mini PC NAS Pre-buy Scorecard</strong>
        <span>Answer seven checks and get a low, medium, or high risk read before checkout.</span>
      </a>
      <a href="/wiki/proxmox-mini-pc-nas-checklist/">
        <strong>Proxmox Mini PC NAS Checklist</strong>
        <span>CPU, RAM, NIC, storage, cooling, and backup fit before purchase.</span>
      </a>
      <a href="/wiki/intel-n100-proxmox-nas/">
        <strong>Should You Buy Intel N100 For a Proxmox NAS?</strong>
        <span>Low-power mini PC fit with storage and NIC caveats.</span>
      </a>
      <a href="/wiki/proxmox-zfs-mirror-mini-pc/">
        <strong>Proxmox ZFS Mirror On Mini PC</strong>
        <span>Two-drive local storage planning for small hosts.</span>
      </a>
      <a href="/wiki/hba-passthrough-truenas-vm/">
        <strong>HBA Passthrough To TrueNAS VM</strong>
        <span>IOMMU, storage ownership, boot separation, and recovery checks.</span>
      </a>
    </div>
  </section>
</BaseLayout>
