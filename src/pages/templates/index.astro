---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageBySlug } from "../../data/homelab-pages.js";
import { featuredOffers } from "../../data/offers.js";
---
<BaseLayout title="Homelab Planning Templates | Homelab Fit" description="Homelab Fit planning paths for Proxmox mini PC buyers, storage layouts, passthrough checks, and operations runbooks.">
  <section class="page-head">
    <p class="eyebrow">Templates</p>
    <h1>Planning paths for Proxmox homelab builders</h1>
    <p>These packs turn compatibility pages into reusable buyer scorecards, storage planners, passthrough briefs, and recovery runbooks.</p>
  </section>

  <section class="template-list">
    {featuredOffers.map((offer) => (
      <article class="template-panel" id={offer.id}>
        <div>
          <p class="eyebrow">{offer.eyebrow}</p>
          <h2>{offer.title}</h2>
          <p>{offer.body}</p>
          <p><strong>Best fit:</strong> {offer.fit}</p>
          {offer.resourceHref && <a class="button-link" href={offer.resourceHref}>{offer.resourceLabel}</a>}
        </div>
        <div class="template-links">
          <h3>Start with these pages</h3>
          {offer.pages.map((slug) => {
            const page = getPageBySlug(slug);
            return page && (
              <a href={`/wiki/${page.slug}/`}>
                <strong>{page.displayTitle}</strong>
                <span>{page.cardDescription}</span>
              </a>
            );
          })}
        </div>
      </article>
    ))}
  </section>

  <section class="content-block">
    <h2>How to use these paths</h2>
    <p>Start with the pack that matches the decision in front of you. A good path should leave you with fewer unknowns: the exact hardware, the disk owner, the network rollback, and the restore test you would run before trusting the build.</p>
  </section>
</BaseLayout>
