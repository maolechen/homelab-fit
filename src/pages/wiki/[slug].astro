---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageBySlug, getRelatedPages, pages } from "../../data/homelab-pages.js";
import { getOfferForPage } from "../../data/offers.js";
import { getHelpHref, highIntentHelpSlugs } from "../../data/help.js";

export function getStaticPaths() {
  return pages.map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const { page } = Astro.props;
const relatedPages = getRelatedPages(page);
const typeLabel = page.page_type.replaceAll("_", " ");
const content = page.content;
const pageTitle = page.displayTitle;
const seoTitle = content?.seo_title ?? `${pageTitle} | Homelab Fit`;
const metaDescription = content?.meta_description ?? content?.summary ?? page.search_intent;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://homelab-fit.example.com").toString();
const appliesTo = content?.applies_to?.join(", ") ?? page.applies_to;
const offer = content ? getOfferForPage(page) : null;
const showHelpCta = content && highIntentHelpSlugs.has(page.slug);
const helpHref = getHelpHref(`${page.displayTitle} build brief`);
const visualByType = {
  hardware_fit: "/media/article-visuals/hardware-fit.svg",
  buyer_checklist: "/media/article-visuals/hardware-fit.svg",
  networking_fit: "/media/article-visuals/networking-fit.svg",
  error_fix: "/media/article-visuals/networking-fit.svg",
  storage_fit: "/media/article-visuals/storage-fit.svg",
  passthrough_fit: "/media/article-visuals/passthrough-fit.svg",
  comparison: "/media/article-visuals/comparison.svg",
  ops_checklist: "/media/article-visuals/ops-checklist.svg"
};
const visualSrc = content?.hero_image ?? visualByType[page.page_type] ?? "/media/article-visuals/hardware-fit.svg";
const visualAlt = content?.image_alt ?? `${pageTitle} editorial diagram`;
const photoByType = {
  hardware_fit: {
    src: "/media/photos/pc-components.jpg",
    alt: "PC components laid out on a desk",
    caption: "Real hardware choices get messy quickly: chassis, expansion, thermals, storage, and recovery all compete for space.",
    credit: "Brecht Corbeel",
    source: "https://unsplash.com/photos/pc-components-sit-on-a-cluttered-desk-GXPK7_d49wk",
    license: "Unsplash License"
  },
  buyer_checklist: {
    src: "/media/photos/pc-components.jpg",
    alt: "PC components laid out on a desk",
    caption: "A good checklist turns a pile of tempting parts into a build that can actually be maintained.",
    credit: "Brecht Corbeel",
    source: "https://unsplash.com/photos/pc-components-sit-on-a-cluttered-desk-GXPK7_d49wk",
    license: "Unsplash License"
  },
  networking_fit: {
    src: "/media/photos/network-switch.jpg",
    alt: "Ethernet cables connected to networking equipment",
    caption: "Networking pages deserve a real cable-and-port reminder: link speed, switch behavior, and bridge mapping are physical problems too.",
    credit: "Albert Stoynov",
    source: "https://unsplash.com/photos/a-close-up-of-a-network-with-wires-connected-to-it-dyUp7WPu5q4",
    license: "Unsplash License"
  },
  error_fix: {
    src: "/media/photos/network-switch.jpg",
    alt: "Ethernet cables connected to networking equipment",
    caption: "Most Proxmox network fixes start with ordinary evidence: link lights, interface names, cables, switch ports, and one known-good test.",
    credit: "Albert Stoynov",
    source: "https://unsplash.com/photos/a-close-up-of-a-network-with-wires-connected-to-it-dyUp7WPu5q4",
    license: "Unsplash License"
  },
  storage_fit: {
    src: "/media/photos/hard-drive.jpg",
    alt: "Close-up of a hard disk drive circuit board",
    caption: "Storage decisions are where homelabs become real infrastructure: endurance, backups, disk ownership, and restore tests all matter.",
    credit: "Bruce Hong",
    source: "https://unsplash.com/photos/black-and-green-computer-hard-disk-drive-0RyLIf84mXU",
    license: "Unsplash License"
  },
  passthrough_fit: {
    src: "/media/photos/pc-components.jpg",
    alt: "PC components laid out on a desk",
    caption: "Passthrough planning is hardware planning: controller ownership, IOMMU groups, boot separation, and a rollback path need to be visible.",
    credit: "Brecht Corbeel",
    source: "https://unsplash.com/photos/pc-components-sit-on-a-cluttered-desk-GXPK7_d49wk",
    license: "Unsplash License"
  },
  comparison: {
    src: "/media/photos/server-rack.jpg",
    alt: "Two server racks filled with electronic components and wires",
    caption: "Comparisons are most useful when they keep the whole environment in view: power, noise, expansion, serviceability, and recovery.",
    credit: "Eric Stoynov",
    source: "https://unsplash.com/photos/two-server-racks-filled-with-electronic-components-and-wires-k27hkqXuveo",
    license: "Unsplash License"
  },
  ops_checklist: {
    src: "/media/photos/server-rack.jpg",
    alt: "Two server racks filled with electronic components and wires",
    caption: "Operations pages should feel grounded: the goal is not novelty, it is a system that can survive updates, outages, and restores.",
    credit: "Eric Stoynov",
    source: "https://unsplash.com/photos/two-server-racks-filled-with-electronic-components-and-wires-k27hkqXuveo",
    license: "Unsplash License"
  }
};
const articlePhoto = content?.editorial_photo ?? photoByType[page.page_type];
const readingPath = content?.reading_path
  ?.map((item) => {
    const linkedPage = getPageBySlug(item.slug);
    return linkedPage ? { ...item, page: linkedPage } : null;
  })
  .filter(Boolean) ?? [];
const decisionScores = content?.decision_scores?.map((score) => Array.isArray(score)
  ? { label: score[0], score: score[1], note: score[2] }
  : score) ?? [];
const decisionMatrix = content?.decision_matrix;
const quickAnswer = content?.quick_answer ?? content?.summary;
const sourceCount = content?.sources?.length ?? 0;
const articleJsonLd = content ? {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: pageTitle,
  description: metaDescription,
  dateModified: content.updated_at,
  datePublished: content.updated_at,
  mainEntityOfPage: canonicalUrl,
  author: {
    "@type": "Organization",
    name: "Homelab Fit"
  },
  citation: content.sources.map((source) => source.url)
} : null;
const normalizeFaq = (item) => Array.isArray(item)
  ? { question: item[0], answer: item[1] }
  : item;
---
<BaseLayout
  title={seoTitle}
  description={metaDescription}
  noindex={!content}
  pageType="article"
  publishedTime={content?.updated_at}
  modifiedTime={content?.updated_at}
>
  {articleJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  )}
  <article class="article">
    <header class="article-head">
      <p class="eyebrow">{typeLabel}</p>
      <h1>{pageTitle}</h1>
      <p>{content?.summary ?? page.search_intent}</p>
      <div class="article-meta">
        <span>Primary query: {page.primary_query}</span>
        <span>Applies to: {appliesTo}</span>
        <span>Opportunity: {page.opportunityScore || page.priority || "TBD"}</span>
        <span>{content ? "Source-backed draft" : "Noindex candidate"}</span>
      </div>
      <p class="article-disclaimer">Independent third-party notes. Verify critical homelab changes against primary docs and your exact hardware revision.</p>
    </header>

    {content ? (
      <>
        <figure class="article-hero-figure">
          <img src={visualSrc} alt={visualAlt} loading="eager" />
          <figcaption>{content?.image_caption ?? "A structured build note for checking hardware, storage, networking, and recovery before the change becomes expensive."}</figcaption>
        </figure>

        <section class="answer-box">
          <h2>Quick Answer</h2>
          <p>{quickAnswer}</p>
        </section>

        {content.verdict && (
          <section class="verdict-card">
            <div>
              <p class="eyebrow">{content.verdict.label ?? "Buyer verdict"}</p>
              <h2>{content.verdict.headline}</h2>
              <p>{content.verdict.recommendation}</p>
            </div>
            <dl>
              <div>
                <dt>Best for</dt>
                <dd>{content.verdict.best_for}</dd>
              </div>
              <div>
                <dt>Avoid if</dt>
                <dd>{content.verdict.avoid_if}</dd>
              </div>
              <div>
                <dt>Biggest risk</dt>
                <dd>{content.verdict.biggest_risk}</dd>
              </div>
            </dl>
          </section>
        )}

        <aside class="trust-strip">
          <span>Last reviewed: {content.last_reviewed ?? content.updated_at}</span>
          <span>{sourceCount} sources checked</span>
          <span>Hardware caveat: verify the exact SKU and revision before buying.</span>
        </aside>

        {content.editorial_intro && (
          <section class="essay-section">
            <p>{content.editorial_intro}</p>
          </section>
        )}

        {content.buyer_scenarios && (
          <section class="content-section choose-path-section">
            <p class="eyebrow">Choose your path</p>
            <h2>If this is your situation, start here</h2>
            <div class="scenario-grid">
              {content.buyer_scenarios.map((scenario) => (
                <a class="scenario-card" href={scenario.href}>
                  <span>{scenario.situation}</span>
                  <strong>{scenario.path}</strong>
                  <small>{scenario.why}</small>
                </a>
              ))}
            </div>
          </section>
        )}

        {content.safe_default && (
          <section class="safe-default">
            <div>
              <p class="eyebrow">Beginner-safe default</p>
              <h2>{content.safe_default.title}</h2>
              <p>{content.safe_default.body}</p>
            </div>
            <ul>{content.safe_default.checks.map((check) => <li>{check}</li>)}</ul>
          </section>
        )}

        {offer && (
          <aside class="conversion-strip">
            <p class="eyebrow">{offer.eyebrow}</p>
            <div>
              <h2>{offer.title}</h2>
              <p>{offer.body}</p>
            </div>
            <a class="button-link" href={offer.href}>{offer.label}</a>
          </aside>
        )}

        {decisionScores.length > 0 && (
          <section class="content-section score-section">
            <h2>Decision Score</h2>
            <div class="score-grid">
              {decisionScores.map((item) => (
                <div class="score-card">
                  <div class="score-topline">
                    <strong>{item.label}</strong>
                    <span>{item.score}/5</span>
                  </div>
                  <div class="score-meter" aria-label={`${item.label} score ${item.score} out of 5`}>
                    <i style={`width: ${Number(item.score) * 20}%`}></i>
                  </div>
                  <p>{item.note}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        {content.upgrade_path && (
          <section class="content-section upgrade-path-section">
            <h2>Upgrade Path</h2>
            <ol>{content.upgrade_path.map((step) => <li>{step}</li>)}</ol>
          </section>
        )}

        <section class="content-section">
          <h2>Key Facts</h2>
          <dl class="fact-list">
            {content.facts.map(([label, value]) => (
              <div>
                <dt>{label}</dt>
                <dd>{value}</dd>
              </div>
            ))}
          </dl>
        </section>

        {content.decision_table && (
          <section class="content-section wide-section">
            <h2>{content.decision_table.title}</h2>
            <div class="comparison-table-wrap">
              <table class="comparison-table">
                <thead>
                  <tr>
                    {content.decision_table.headers.map((header) => <th>{header}</th>)}
                  </tr>
                </thead>
                <tbody>
                  {content.decision_table.rows.map((row) => (
                    <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {decisionMatrix && (
          <section class="content-section wide-section decision-matrix-section">
            <h2>{decisionMatrix.title}</h2>
            <div class="comparison-table-wrap">
              <table class="comparison-table">
                <thead>
                  <tr>
                    {decisionMatrix.headers.map((header) => <th>{header}</th>)}
                  </tr>
                </thead>
                <tbody>
                  {decisionMatrix.rows.map((row) => (
                    <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {content.pre_buy_checks && (
          <section class="content-section prebuy-section">
            <h2>Before You Buy</h2>
            <ol>{content.pre_buy_checks.map((item) => <li>{item}</li>)}</ol>
          </section>
        )}

        {articlePhoto && (
          <figure class="article-photo-figure">
            <img src={articlePhoto.src} alt={articlePhoto.alt} loading="lazy" />
            <figcaption>
              <span>{articlePhoto.caption}</span>
              <a href={articlePhoto.source}>
                Photo by {articlePhoto.credit} on Unsplash
              </a>
              <a href="https://unsplash.com/license">{articlePhoto.license}</a>
            </figcaption>
          </figure>
        )}

        {content.top_risks && (
          <section class="risk-strip">
            <p class="eyebrow">Watch the traps</p>
            <h2>Most expensive beginner risks</h2>
            <ul>{content.top_risks.map((risk) => <li>{risk}</li>)}</ul>
          </section>
        )}

        <section class="detail-grid">
          <div>
            <h2>Recommended Checks</h2>
            <ol>
              {content.steps.map((step) => <li>{step}</li>)}
            </ol>
          </div>
          <div>
            <h2>Verification</h2>
            <ul>
              {content.verification.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </section>

        {showHelpCta && (
          <aside class="help-cta">
            <div>
              <p class="eyebrow">Need a build brief?</p>
              <h2>Capture the host facts before buying or changing storage.</h2>
              <p>Record the exact mini PC, NIC, drives, workloads, passthrough plan, and backup destination so the next decision is based on the real setup.</p>
            </div>
            <a class="button-link secondary" href={helpHref}>Prepare brief</a>
          </aside>
        )}

        {content.field_notes && (
          <section class="field-note">
            <p class="eyebrow">{content.field_notes.eyebrow ?? "Field note"}</p>
            <h2>{content.field_notes.title}</h2>
            <p>{content.field_notes.body}</p>
          </section>
        )}

        <section class="content-section">
          <h2>Warnings</h2>
          <ul>
            {content.warnings.map((warning) => <li>{warning}</li>)}
          </ul>
        </section>

        {(content.best_for || content.not_for) && (
          <section class="fit-grid">
            {content.best_for && (
              <div>
                <h2>Best For</h2>
                <ul>{content.best_for.map((item) => <li>{item}</li>)}</ul>
              </div>
            )}
            {content.not_for && (
              <div>
                <h2>Not For</h2>
                <ul>{content.not_for.map((item) => <li>{item}</li>)}</ul>
              </div>
            )}
          </section>
        )}

        {content.common_mistakes && (
          <section class="content-section">
            <h2>Common Beginner Traps</h2>
            <ul>{(content.beginner_traps ?? content.common_mistakes).map((mistake) => <li>{mistake}</li>)}</ul>
          </section>
        )}

        {content.saveable_summary && (
          <section class="saveable-summary">
            <p class="eyebrow">Save this before checkout</p>
            <h2>{content.saveable_summary.title}</h2>
            <ul>{content.saveable_summary.items.map((item) => <li>{item}</li>)}</ul>
          </section>
        )}

        <aside class="printable-cta">
          <div>
            <p class="eyebrow">Save for later</p>
            <h2>Use the mini PC NAS pre-buy scorecard before checkout.</h2>
            <p>Print or save the checklist, then come back to this page when one of the risk checks fails.</p>
          </div>
          <a class="button-link" href="/resources/mini-pc-nas-scorecard/">Open scorecard</a>
        </aside>

        {content.examples && (
          <section class="content-section">
            <h2>Examples</h2>
            <div class="example-list">
              {content.examples.map((example) => (
                <figure class="code-example">
                  <figcaption><strong>{example.title}</strong></figcaption>
                  <pre><code>{example.code}</code></pre>
                </figure>
              ))}
            </div>
          </section>
        )}

        {content.faq && (
          <section class="content-section">
            <h2>FAQ</h2>
            <div class="qa-list">
              {content.faq.map((item) => {
                const faq = normalizeFaq(item);
                return (
                  <details>
                    <summary>{faq.question}</summary>
                    <p>{faq.answer}</p>
                  </details>
                );
              })}
            </div>
          </section>
        )}

        <section class="content-section">
          <h2>Sources</h2>
          <div class="source-list">
            {content.sources.map((source) => (
              <a class="source-link" href={source.url}>
                <strong>{source.title}</strong>
                <span>Accessed {source.accessed_at}</span>
              </a>
            ))}
          </div>
        </section>

        {readingPath.length > 0 && (
          <section class="reading-path">
            <p class="eyebrow">What to read next</p>
            <h2>Follow the decision path</h2>
            <div class="reading-path-list">
              {readingPath.map((item, index) => (
                <a href={`/wiki/${item.slug}/`}>
                  <span>{index + 1}</span>
                  <strong>{item.label ?? item.page.displayTitle}</strong>
                  <small>{item.reason}</small>
                </a>
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <section class="answer-box">
        <h2>Draft Status</h2>
        <p>This candidate page is marked <strong>noindex</strong> until it has source-backed facts, fit criteria, verification checks, warnings, and sources.</p>
      </section>
    )}

    <section class="content-section">
      <h2>Related Pages</h2>
      <div class="related-list">
        {relatedPages.map((related) => (
          <a href={`/wiki/${related.slug}/`}>
            <strong>{related.displayTitle}</strong>
            <span>{related.cardDescription}</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
