---
import Analytics from "../components/Analytics.astro";
import { siteConfig } from "../data/site.js";

const {
  title = siteConfig.name,
  description = siteConfig.description,
  noindex = false,
  pageType = "website",
  publishedTime,
  modifiedTime
} = Astro.props;
const siteOrigin = Astro.site ?? "https://homelab-fit.example.com";
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const siteUrl = new URL("/", siteOrigin).toString();
const feedUrl = new URL("/rss.xml", siteOrigin).toString();
const siteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.name,
  url: siteUrl,
  inLanguage: siteConfig.language,
  publisher: {
    "@type": "Organization",
    name: siteConfig.name
  },
  potentialAction: {
    "@type": "SearchAction",
    target: `${new URL("/pages/", siteOrigin).toString()}?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};
const ogImageUrl = new URL("/og-default.svg", siteOrigin).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content={siteConfig.themeColor} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href={feedUrl} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={pageType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={`${siteConfig.name}: Proxmox homelab compatibility notes`} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
    <Analytics />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <span class="brand-mark">HF</span>
        <span>{siteConfig.name}</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="/pages/">Pages</a>
        <a href="/types/">Types</a>
        <a href="/templates/">Templates</a>
        <a href="/resources/homelab-build-checklist/">Checklist</a>
        <a href="/about/">About</a>
        <a href="/legal/">Legal</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>{siteConfig.disclaimer}</span>
      <span class="footer-links">
        <a href="/legal/">Legal</a>
        <a href={siteConfig.officialDocsUrl}>Proxmox docs</a>
      </span>
    </footer>
  </body>
</html>
